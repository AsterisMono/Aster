--- a/chrome/browser/ui/views/side_panel/side_panel_resize_area.cc
+++ b/chrome/browser/ui/views/side_panel/side_panel_resize_area.cc
@@ -4,6 +4,8 @@
 
 #include "chrome/browser/ui/views/side_panel/side_panel_resize_area.h"
 
+#include <algorithm>
+
 #include "base/functional/bind.h"
 #include "base/i18n/rtl.h"
 #include "chrome/browser/ui/browser_element_identifiers.h"
@@ -147,16 +149,31 @@ void SidePanelResizeArea::Layout(PassKey
   gfx::Rect contents_bounds = parent()->GetContentsBounds();
 
   gfx::Rect resize_bounds;
-  if ((side_panel_->IsRightAligned() && !base::i18n::IsRTL()) ||
-      (!side_panel_->IsRightAligned() && base::i18n::IsRTL())) {
+  const bool resize_on_left_edge =
+      (side_panel_->IsRightAligned() && !base::i18n::IsRTL()) ||
+      (!side_panel_->IsRightAligned() && base::i18n::IsRTL());
+  if (resize_on_left_edge) {
     resize_bounds = gfx::Rect(local_bounds.x(), local_bounds.y(),
                               contents_bounds.x(), local_bounds.height());
   } else {
     resize_bounds = gfx::Rect(contents_bounds.right(), local_bounds.y(),
                               local_bounds.right() - contents_bounds.right(),
                               local_bounds.height());
   }
 
+  // aster: The edge-to-edge side panel has no border, so the
+  // normal resize area above is zero-width. Overlay a small invisible hit
+  // target inside the content-facing edge without reintroducing a visual gap.
+  if (resize_bounds.width() == 0 && local_bounds.width() > 0) {
+    constexpr int kEdgeToEdgeResizeAreaWidth = 8;
+    const int resize_width =
+        std::min(kEdgeToEdgeResizeAreaWidth, local_bounds.width());
+    resize_bounds = gfx::Rect(
+        resize_on_left_edge ? local_bounds.x()
+                            : local_bounds.right() - resize_width,
+        local_bounds.y(), resize_width, local_bounds.height());
+  }
+
   SetBoundsRect(resize_bounds);
 }
 
