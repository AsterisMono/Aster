+Name: Sidebery
+Short Name: sidebery
+URL: https://github.com/AsterisMono/sidebery
+Version: 5.6.1-chromium
+License: MIT
+License File: LICENSE
+Shipped: yes
+Security Critical: yes
+
+Description:
+Sidebery - a vertical tabs and bookmarks side panel extension, ported to
+Chromium (MV3) from the original Firefox add-on by mbnuqw. Bundled as a trusted
+component extension and loaded from the resource bundle; it hosts the browser's
+vertical tab UI in the native side panel.
+
+Local Modifications:
+None. The archive is fetched via downloads.ini and unpacked to this directory.
+The manifest already contains a "key" that pins the extension id to
+dcmmcmgcedhnmcabgkkbfdnjiebgafoa.
diff --git a/third_party/sidebery/generate_file_list.py b/third_party/sidebery/generate_file_list.py
new file mode 100644
index 0000000..4a6bfcf
--- /dev/null
+++ b/third_party/sidebery/generate_file_list.py
@@ -0,0 +1,28 @@
+# Copyright 2025 The aster Authors. All rights reserved.
+# Use of this source code is governed by a BSD-style license that can be
+# found in the LICENSE file.
+
+# Emits a generate_grd manifest (a base directory plus the list of every file
+# below it) so that all files shipped with the bundled Sidebery component
+# extension are packed into the resource bundle.
+
+import json
+import os
+from pathlib import Path
+from sys import argv
+
+src = Path(argv[1])
+out_file = argv[2]
+
+with open(out_file, 'w') as f:
+    json.dump(
+        {
+            'base_dir': src.as_posix(),
+            'files': [
+                (Path(root) / name).relative_to(src).as_posix()
+                for root, _, names in os.walk(src)
+                for name in names
+            ],
+        },
+        f,
+    )
