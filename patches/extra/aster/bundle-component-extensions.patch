+// aster: Load the bundled uBlock Origin as a trusted component
+// extension from the resource bundle.
+void ComponentLoader::AddUBlock() {
+  Add(IDR_UBLOCK_MANIFEST_JSON,
+      base::FilePath(FILE_PATH_LITERAL("ublock")));
+
+  // uBlock Origin's manifest uses __MSG_*__ placeholders, so localize it by
+  // reading the _locales message catalogs out of the resource bundle.
+  ComponentExtensionInfo& info = component_extensions_.back();
+  std::string error;
+  bool localized = extension_l10n_util::LocalizeExtension(
+      info.root_directory, &info.manifest,
+      extension_l10n_util::GzippedMessagesPermission::kAllowForTrustedSource,
+      &error, /*is_component=*/true);
+  if (!localized) {
+    LOG(ERROR) << "Failed to localize uBlock Origin component extension: "
+               << error;
+  }
+}
+
+// aster: Load the bundled Sidebery vertical-tabs extension as a
+// trusted component extension from the resource bundle. Its manifest already
+// contains a "key", so its extension id is stable.
+void ComponentLoader::AddSidebery() {
+  Add(IDR_SIDEBERY_MANIFEST_JSON,
+      base::FilePath(FILE_PATH_LITERAL("sidebery")));
+
+  // Sidebery's manifest uses __MSG_*__ placeholders, so localize it by reading
+  // the _locales message catalogs out of the resource bundle.
+  ComponentExtensionInfo& info = component_extensions_.back();
+  std::string error;
+  bool localized = extension_l10n_util::LocalizeExtension(
+      info.root_directory, &info.manifest,
+      extension_l10n_util::GzippedMessagesPermission::kAllowForTrustedSource,
+      &error, /*is_component=*/true);
+  if (!localized) {
+    LOG(ERROR) << "Failed to localize Sidebery component extension: " << error;
+  }
+}
