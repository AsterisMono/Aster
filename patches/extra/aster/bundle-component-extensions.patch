diff --git a/third_party/sidebery/BUILD.gn b/third_party/sidebery/BUILD.gn
new file mode 100644
index 0000000..8462faa
--- /dev/null
+++ b/third_party/sidebery/BUILD.gn
@@ -0,0 +1,47 @@
+# Copyright 2025 The aster Authors. All rights reserved.
+# Use of this source code is governed by a BSD-style license that can be
+# found in the LICENSE file.
+
+import("//tools/grit/grit_rule.gni")
+import("//ui/webui/resources/tools/generate_grd.gni")
+
+file_list = "$target_gen_dir/files.json"
+generated_grd = "$target_gen_dir/sidebery_resources.grd"
+
+# Enumerate the extension's files (delivered by downloads.ini) at gen time.
+action("generate_file_list") {
+  script = "generate_file_list.py"
+  args = [
+    rebase_path("."),
+    rebase_path(file_list),
+  ]
+  inputs = [ "manifest.json" ]
+  outputs = [ file_list ]
+}
+
+generate_grd("sidebery_grd") {
+  out_grd = generated_grd
+  grd_prefix = "sidebery"
+  resource_path_prefix = "sidebery"
+  manifest_files = [ file_list ]
+  deps = [ ":generate_file_list" ]
+}
+
+grit("sidebery") {
+  source = generated_grd
+
+  # Required because the .grd is generated.
+  enable_input_discovery_for_gn_analyze = false
+  use_brotli = true
+
+  output_dir = "$target_gen_dir/resources"
+
+  outputs = [
+    "grit/sidebery_resources.h",
+    "grit/sidebery_resources_map.cc",
+    "grit/sidebery_resources_map.h",
+    "sidebery_resources.pak",
+  ]
+
+  deps = [ ":sidebery_grd" ]
+}
